# Server
PORT=5002

# MongoDB connection string
DATABASE=mongodb+srv://<db-user>:<db-password>@<cluster>.mongodb.net/<db-name>?retryWrites=true&w=majority

# Admin API key (legacy auth fallback for write endpoints)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=<generate-a-32-byte-hex-string>

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-domain,https://your-admin-domain

# Cloudinary - Jobs / Blog images
CLOUD_NAME=<your-cloudinary-cloud-name>
API_KEY=<your-cloudinary-api-key>
API_SECRET=<your-cloudinary-api-secret>

# Cloudinary - Ads / Poster images (separate account)
CLOUD_NAME2=<your-ads-cloudinary-cloud-name>
API_KEY2=<your-ads-cloudinary-api-key>
API_SECRET2=<your-ads-cloudinary-api-secret>

# Firebase Admin SDK (for token verification)
FIREBASE_PROJECT_ID=<your-firebase-project-id>
FIREBASE_PRIVATE_KEY_ID=<your-firebase-private-key-id>
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<your-key-body>\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=<your-firebase-client-email>
FIREBASE_CLIENT_ID=<your-firebase-client-id>

# Session-cookie click tracker pepper (required by middleware/sessionCookie.js)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CLICK_HASH_PEPPER=<generate-a-32-byte-hex-string>

# Scraper — AI Provider (gemini, groq, claude, openrouter)
AI_PROVIDER=gemini
GEMINI_API_KEY=<your-gemini-api-key>
GROQ_API_KEY=<your-groq-api-key>
GROQ_MODEL=llama-3.3-70b-versatile
CLAUDE_API_KEY=<your-claude-api-key>
CLAUDE_MODEL=claude-haiku-4-5-20251001
OPENROUTER_API_KEY=<your-openrouter-api-key>
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Scraper — optional fetch proxy (5K free/month)
SCRAPERAPI_KEY=<your-scraperapi-key>

# Scraper — Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=<your-telegram-bot-token>
TELEGRAM_CHAT_ID=<your-telegram-chat-id>

# Scraper — Admin API secret (separate from ADMIN_API_KEY; protects /api/admin/scrape/*)
ADMIN_SECRET=<generate-a-32-byte-hex-string>

# Blog — Cloudinary folder for blog images (uses same Cloudinary account as jobs)
BLOG_CLOUDINARY_FOLDER=blog

# Blog — Next.js revalidation webhook (optional; SITE_REVALIDATE_URL is the legacy alias)
NEXT_REVALIDATION_URL=<your-nextjs-revalidate-endpoint>
SITE_REVALIDATE_URL=<your-nextjs-revalidate-endpoint>
REVALIDATE_SECRET=<shared-secret-with-frontend>

# Blog — RSS feed metadata
SITE_URL=https://your-frontend-domain
SITE_TITLE=Your Site Blog
SITE_DESCRIPTION=Your site description

# Node environment (controls cookie secure flag)
NODE_ENV=development
